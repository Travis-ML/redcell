# Model (LiteLLM format). Local-first examples first, cloud below.
#   hosted_vllm/<model>         (self-hosted vLLM)  + AGENT_API_BASE
#   ollama/llama3.1             (local Ollama)
#   anthropic/claude-opus-4-8   (cloud)             + ANTHROPIC_API_KEY
#   openai/gpt-4o               (cloud)             + OPENAI_API_KEY
AGENT_MODEL=anthropic/claude-opus-4-8

# OpenAI-compatible endpoint override (self-hosted vLLM / LM Studio).
#   AGENT_API_BASE=http://YOUR_HOST:8000/v1
AGENT_API_BASE=
AGENT_API_KEY=

# Provider keys (set whichever you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Generation
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=1024
AGENT_MAX_ITERATIONS=25
AGENT_LOG_LEVEL=INFO
# Structured-event output. Set JSON + a file to get a JSONL event sink per scan
# (every event carries a run_id; tool_end includes duration_ms and the result).
AGENT_LOG_JSON=false
# AGENT_LOG_FILE=runs/events.jsonl
# Silence the MCP transport's benign teardown-race logs (SSE ClosedResourceError +
# "Session termination failed: 202"). Set false to keep them when debugging it.
AGENT_LOG_QUIET_MCP_TRANSPORT=true

# OpenAI-compatible server (point Open WebUI / Garak / Promptfoo here)
AGENT_SERVER_HOST=0.0.0.0
AGENT_SERVER_PORT=8800
AGENT_MODEL_ID=redcell
AGENT_SERVER_API_KEY=

# Stateful sessions: send this header (or a body `session_id`) and redcell
# remembers that conversation server-side, so the client sends only the new turn
# (promptfoo "client-generated session id" mode). Omit the header for the default
# stateless behavior (client resends full history).
AGENT_SESSION_HEADER=x-redcell-session
AGENT_SESSION_TTL_SECONDS=3600.0
AGENT_SESSION_MAX=1000

# Security controls (secure-by-default). Flip any of these to recreate the
# deliberately vulnerable target for red-team baselining.
#   AGENT_SAFETY_PROMPT=false       drop the safety policy from the system prompt
#   AGENT_GUARDRAILS=false          disable the input/output guardrail
#   AGENT_MCP_TOOL_DENYLIST=shell,filesystem   drop dangerous gateway tools
AGENT_SAFETY_PROMPT=true
AGENT_GUARDRAILS=true
AGENT_MCP_TOOL_DENYLIST=
# Subset of safety rules to include (empty = all). Lets you measure each rule's
# individual contribution. Names: harm,copyright,truthfulness,commitments,disclosure,fairness
AGENT_SAFETY_RULES=

# SearXNG instance backing the web_search tool
AGENT_SEARXNG_URL=http://127.0.0.1:8989

# AgentGateway — serve launches it and proxies MCP traffic through it
AGENT_GATEWAY_BIN=agentgateway
AGENT_GATEWAY_CONFIG=agentgateway/config.yaml
AGENT_GATEWAY_HOST=127.0.0.1
AGENT_GATEWAY_PORT=3030
AGENT_GATEWAY_URL=http://127.0.0.1:3030/mcp
AGENT_GATEWAY_AUTOSTART=true
AGENT_GATEWAY_READY_TIMEOUT=30.0

# Qdrant (RAG store) — serve brings it up via `docker compose up -d`, the same
# way it launches the gateway. Needs Docker; degrades gracefully if absent.
# Set AUTOSTART=false to manage Qdrant yourself; STOP_ON_EXIT=true to also stop
# the container when serve exits (it's left running by default).
AGENT_QDRANT_AUTOSTART=true
AGENT_QDRANT_COMPOSE_FILE=docker-compose.yml
AGENT_QDRANT_SERVICE=qdrant
AGENT_QDRANT_HOST=127.0.0.1
AGENT_QDRANT_PORT=6333
AGENT_QDRANT_READY_TIMEOUT=30.0
AGENT_QDRANT_STOP_ON_EXIT=false

# Document ingestion — at startup, chunk PDFs in DOCS_DIR and store them in
# Qdrant so the agent can retrieve them (qdrant-find). A hash manifest skips
# files already ingested unchanged. Drop your PDFs in ./documents (flat folder).
AGENT_DOCS_AUTOLOAD=true
AGENT_DOCS_DIR=documents
AGENT_DOCS_MANIFEST_PATH=.redcell/ingested.json
AGENT_DOCS_CHUNK_SIZE=1000
AGENT_DOCS_CHUNK_OVERLAP=150
