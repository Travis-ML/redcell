# Model (LiteLLM format). Local-first examples first, cloud below.
#   hosted_vllm/<model>         (self-hosted vLLM)  + AGENT_API_BASE
#   ollama/llama3.1             (local Ollama)
#   anthropic/claude-opus-4-8   (cloud)             + ANTHROPIC_API_KEY
#   openai/gpt-4o               (cloud)             + OPENAI_API_KEY
AGENT_MODEL=anthropic/claude-opus-4-8

# OpenAI-compatible endpoint override (self-hosted vLLM / LM Studio).
#   AGENT_API_BASE=http://YOUR_HOST:8000/v1
AGENT_API_BASE=
AGENT_API_KEY=

# Provider keys (set whichever you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Generation
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=1024
AGENT_MAX_ITERATIONS=25
AGENT_LOG_LEVEL=INFO

# OpenAI-compatible server (point Open WebUI / Garak / Promptfoo here)
AGENT_SERVER_HOST=0.0.0.0
AGENT_SERVER_PORT=8800
AGENT_MODEL_ID=redcell
AGENT_SERVER_API_KEY=

# SearXNG instance backing the web_search tool
AGENT_SEARXNG_URL=http://127.0.0.1:8989

# AgentGateway — serve launches it and proxies MCP traffic through it
AGENT_GATEWAY_BIN=agentgateway
AGENT_GATEWAY_CONFIG=agentgateway/config.yaml
AGENT_GATEWAY_HOST=127.0.0.1
AGENT_GATEWAY_PORT=3030
AGENT_GATEWAY_URL=http://127.0.0.1:3030/mcp
AGENT_GATEWAY_AUTOSTART=true
AGENT_GATEWAY_READY_TIMEOUT=30.0
